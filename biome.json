{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["**", "!**/*.ejs"]
	},
	"overrides": [
		{
			"includes": ["**/*.config.{js,ts}"],
			"linter": { "rules": { "style": { "noDefaultExport": "off" } } }
		}
	],
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": "error",
			"correctness": {
				"noGlobalDirnameFilename": "error",
				"useImportExtensions": "error"
			},
			"performance": {
				"noAwaitInLoops": "error"
			},
			"security": "error",
			"style": {
				"noCommonJs": "error",
				"noDefaultExport": "error",
				"noExportedImports": "error",
				"noNegationElse": "error",
				"noNestedTernary": "error",
				"noParameterAssign": "error",
				"noProcessEnv": "error",
				"noRestrictedImports": {
					"level": "error",
					"options": {
						"patterns": [
							{
								"group": "../**/*",
								"message": "Avoid relative parent imports. Use `#root/` absolute paths instead."
							}
						]
					}
				},
				"noSubstr": "error",
				"noUnusedTemplateLiteral": "error",
				"noUselessElse": "error",
				"noYodaExpression": "error",
				"useAtIndex": "error",
				"useCollapsedIf": "error",
				"useConsistentArrowReturn": "error",
				"useConsistentObjectDefinitions": "error",
				"useDefaultParameterLast": "error",
				"useDefaultSwitchClause": "error",
				"useFilenamingConvention": {
					"level": "error",
					"options": {
						"filenameCases": ["kebab-case"]
					}
				},
				"useForOf": "error",
				"useNodeAssertStrict": "error",
				"useNumericSeparators": "error",
				"useObjectSpread": "error",
				"useShorthandAssign": "error",
				"useThrowNewError": "error"
			},
			"suspicious": {
				"noConsole": "error",
				"noConstantBinaryExpressions": "error",
				"noImportCycles": "error",
				"noVar": "error",
				"useAwait": "error",
				"useGuardForIn": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"css": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							":NODE:",
							":BLANK_LINE:",
							[":PACKAGE_WITH_PROTOCOL:", ":PACKAGE:"],
							":BLANK_LINE:",
							":ALIAS:",
							":BLANK_LINE:",
							":PATH:"
						]
					}
				},
				"useSortedProperties": "on"
			}
		}
	}
}
